# Generated by Cargo
# will have compiled files and executables
debug
target
fuzz/corpus/parse_display_loop.backup-*/
fuzz/corpus/
!fuzz/corpus/
fuzz/corpus/*
!fuzz/corpus/matching_timeout/
fuzz/corpus/matching_timeout/*
!fuzz/corpus/matching_timeout/simple_recursive_target
!fuzz/corpus/matching_timeout/cytosporins_generation_38_a
!fuzz/corpus/matching_timeout/cytosporins_generation_38_b
!fuzz/corpus/matching_timeout/carotenoid_record_slow
!fuzz/corpus/matching_timeout/carotenoid_broad_disconnected
!fuzz/corpus/matching_timeout/alkaloid_recursive_component
!fuzz/corpus/matching_timeout/alkaloid_short_recursive
!fuzz/corpus/matching_timeout/large_recursive_pathology
fuzz/artifacts/
fuzz/target/
fuzz/.tmp*/
fuzz/Cargo.lock
fuzz-*.log

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
